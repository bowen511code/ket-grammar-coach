# Backend environment variables for local development.
# Copy this file to .env and adjust values if needed.
# Database config is optional for the current MVP stage.

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=ket
DB_PASSWORD=ket
DB_NAME=ket_grammar

# Optional unified connection string for future use:
# DATABASE_URL=postgresql://ket:ket@127.0.0.1:5432/ket_grammar

# Phase 1.5: OpenAI-compatible API for controlled LLM question generation.
# If OPENAI_API_KEY is unset or empty, backend falls back to template-based generation.
# OPENAI_BASE_URL and OPENAI_MODEL are optional (defaults: OpenAI API URL and gpt-4o-mini).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
